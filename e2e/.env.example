# Web origin where the React dev server is served (127.0.0.1 avoids IPv6 localhost issues)
E2E_BASE_URL=http://127.0.0.1:3000

# Sails API origin used for Playwright APIRequestContext helpers
E2E_API_BASE_URL=http://127.0.0.1:1337

# Seeded database user (see server/db/seeds/default.js)
E2E_DEMO_USER=demo
E2E_DEMO_PASSWORD=demo
