# https://docs.4gaboards.com/docs/dev/install/manual-vars

# Required (IPv4 avoids Node/browser resolving `localhost` to ::1 when the API only listens on IPv4)
BASE_URL=http://127.0.0.1:1337
# Use 127.0.0.1 if `localhost` resolves to IPv6 first and your Postgres only listens on IPv4.
DATABASE_URL=postgresql://postgres@127.0.0.1:5432/4gaBoards
SECRET_KEY=notsecretkey

# Add optional 4ga Boards instance variables here

# Do not edit this
TZ=UTC
