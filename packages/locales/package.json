{
  "name": "@4gaboards/locales",
  "version": "1.0.0",
  "private": true,
  "author": "RARgames",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "import": "./dist/esm/renderer.js",
      "require": "./dist/cjs/renderer.js"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "require": "./dist/cjs/*.js"
    }
  },
  "dependencies": {
    "@4gaboards/enums": "workspace:*",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "glob": "^13.0.6",
    "rimraf": "^6.1.3",
    "rollup": "^4.25.1",
    "rollup-plugin-dts": "^6.4.1"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint ."
  }
}
